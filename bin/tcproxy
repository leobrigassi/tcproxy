#!/bin/bash
# shellcheck shell=bash disable=SC1091
# tcproxy — dispatcher.
# In the source repo this sources lib/*.sh. In release form, the build
# script concatenates the libs above this file and strips the source
# block below, producing a single self-contained tcproxy script suitable
# for distribution via `wget | bash`.

# === BEGIN SOURCE-TIME BLOCK (stripped by scripts/build.sh) ===
TCPROXY_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TCPROXY_LIB_DIR="$(cd "$TCPROXY_BIN_DIR/../lib" && pwd)"
source "$TCPROXY_LIB_DIR/config.sh"
source "$TCPROXY_LIB_DIR/common.sh"
source "$TCPROXY_LIB_DIR/ui.sh"
source "$TCPROXY_LIB_DIR/vm.sh"
source "$TCPROXY_LIB_DIR/mount.sh"
source "$TCPROXY_LIB_DIR/provision.sh"
source "$TCPROXY_LIB_DIR/systemd.sh"
source "$TCPROXY_LIB_DIR/updater.sh"
source "$TCPROXY_LIB_DIR/installer.sh"
# === END SOURCE-TIME BLOCK ===

SCRIPT_COMMAND="$0 $*"

check_dependencies

# --startup-boot is systemd's entry point. It must run before folder
# creation, cwd, or env loading because the unit sets WorkingDirectory
# and EnvironmentFile for us.
if [[ $1 == "--startup-boot" ]]; then
    # LOG_FILE is derived from TCPROXY_PATH (provided by EnvironmentFile)
    # in case an older env file written by v3.2.0 omitted it.
    LOG_FILE="${LOG_FILE:-$TCPROXY_PATH/log-tcproxy.txt}"
    tcproxy_up
    exit 0
fi

# Ensure a usable sudo session; if not, bail out with install instructions.
if sudo -n true 2>/dev/null; then
    :
else
    sudo -v 2>&1
    if sudo -n true 2>/dev/null; then
        echo "Sudo session is now active and validated."
    else
        echo "Sudo session is not active. A password is required."
        echo "Please run [ ./tcproxy --install ] from the install directory [ tcproxy/ ] and insert your sudo password when prompted."
        create_tcproxy_folder
        download_latest_script
        exit 1
    fi
fi

if [[ "$(pwd)" =~ \  ]]; then
    echo "[ERROR] The installation path contains spaces, which is not supported."
    echo "Please move the script to a directory without spaces and try again."
    exit 1
fi

# Piped `wget | bash` has no tty AND no argument: force --install.
# The `$# -eq 0` guard is what lets agents / cron / systemd run
# `tcproxy -d`, `-u`, `-r`, `--disable-service`, etc. without a tty —
# without it, every non-interactive invocation was silently rewritten
# to `--install` and hit the whiptail install wizard.
if [ ! -t 0 ] && [ $# -eq 0 ]; then
    set -- "--install"
    WEB_INSTALL="TRUE"
fi

# v3.2.2: if the uninstalled marker is present, refuse any operational
# command centrally. Only help/version/install/uninstall are allowed
# through. This prevents `-u`/`-s`/etc. from entering QEMU load loops
# against deleted assets (BUG-2) and stops `create_tcproxy_folder` from
# silently writing an empty .tcproxy.env on uninstalled systems.
if [[ -f "$(pwd)/.tcproxy-uninstalled" ]]; then
    case "$1" in
        -h|--help|-v|--version|-i|--install|--uninstall|"")
            : ;;
        *)
            echo "GNU tcproxy: mount Time Capsule / AirPort Extreme on debian kernels 5.15+."
            echo "tcproxy: [WARNING] file .tcproxy-uninstalled detected."
            echo "Uninstalled status detected. Run [./tcproxy --install] to setup your system."
            echo ""
            echo "tcproxy: command refused. Try [ ./tcproxy --help ] for more options."
            exit 1
            ;;
    esac
fi

if ! load_env_if_exists; then
    echo "[INFO] Installation not detected. Run [./tcproxy --install] to setup your system."
    create_tcproxy_folder
fi
# Heal env files written by v3.2.0, which stopped persisting LOG_FILE.
# Without this, every log* redirect (>> "$LOG_FILE") errors on existing
# installs.  TCPROXY_PATH is always present — either from the env file
# (healthy install) or set by create_tcproxy_folder above.
LOG_FILE="${LOG_FILE:-$TCPROXY_PATH/log-tcproxy.txt}"

case "$1" in
    -h|--help)
        DESCR_COM="Showing help menu..."; header
        help_menu
        footer
        ;;
    -v|--version)
        logm "tcproxy: $TCPROXY_COMMIT"
        footer
        ;;
    --uninstall)
        DESCR_COM="Uninstalling tcproxy..."; header
        if ! load_env_if_exists; then
            echo "[INFO] Installation not detected. Run [./tcproxy --install] to setup your system."
            footer
            exit 1
        fi
        do_uninstall
        footer
        ;;
    -i|--install)
        DESCR_COM="Installing..."; header
        do_install
        footer
        ;;
    -l|--log)
        DESCR_COM="Printing last 100 lines from log..."; header
        tail -n 100 "$LOG_FILE"
        footer
        ;;
    -d|--down)
        # Uninstalled-marker case already handled by central guard above.
        # This check catches the "env file exists but never completed
        # install" edge case — TC_PASSWORD is required for umount logging
        # / stop flow sanity.
        if [[ -z "$TC_PASSWORD" ]]; then
            DESCR_COM="[WARNING]"; header
            echo "[INFO] Installation not detected. Run [./tcproxy --install] to setup your system."
            footer
            exit 1
        fi
        DESCR_COM="Umounting share and stopping VM..."; header
        umount_srv_tcproxy
        sleep 5
        stopping_VM
        footer
        ;;
    -u|--up)
        # v3.2.2: added TC_PASSWORD sanity check to match -d/-r. The
        # uninstalled-marker case is already handled by the central guard.
        if [[ -z "$TC_PASSWORD" ]]; then
            DESCR_COM="[WARNING]"; header
            echo "[INFO] Installation not detected. Run [./tcproxy --install] to setup your system."
            footer
            exit 1
        fi
        DESCR_COM="Loading and mounting VM..."; header
        tcproxy_up
        footer
        ;;
    -s|--ssh)
        # v3.2.2: added TC_PASSWORD sanity check (SSH into a non-existent
        # VM was the same failure class as BUG-2).
        if [[ -z "$TC_PASSWORD" ]]; then
            DESCR_COM="[WARNING]"; header
            echo "[INFO] Installation not detected. Run [./tcproxy --install] to setup your system."
            footer
            exit 1
        fi
        DESCR_COM="Accessing VM via SSH..."; header
        ssh_vm
        footer
        ;;
    -r|--restart)
        if [[ -z "$TC_PASSWORD" ]]; then
            DESCR_COM="[WARNING]"; header
            echo "[INFO] Installation not detected. Run [./tcproxy --install] to setup your system."
            footer
            exit 1
        fi
        DESCR_COM="Restarting VM and remounting share..."; header
        umount_srv_tcproxy
        stopping_VM
        sleep 5
        tcproxy_up
        footer
        ;;
    --enable-service)
        DESCR_COM="Enabling startup service..."; header
        if [[ -z "$TCPROXY_PATH" || -z "$TC_IP" || -z "$TC_PASSWORD" ]]; then
            echo "[ERROR] tcproxy has not been installed yet. Run [./tcproxy --install] first."
            echo "        --enable-service needs a working configuration (env file) to boot from."
            footer
            exit 1
        fi
        STARTUP_MOUNT=Y
        tcproxy_systemd_setup
        install_system_service
        save_env
        post_install_cleanup
        footer
        ;;
    --disable-service)
        DESCR_COM="Disabling startup service..."; header
        remove_system_service
        # -f: staging files may already be gone if --enable-service was
        # never run or post_install_cleanup already removed them.
        logsc sudo rm -f "$TCPROXY_PATH/.tcproxy-boot-load.service"
        logsc sudo rm -f "$TCPROXY_PATH/.tcproxy-boot-load.timer"
        footer
        ;;
    "")
        if [[ -f "$(pwd)/.tcproxy-uninstalled" ]]; then
            DESCR_COM="[WARNING] file .tcproxy-uninstalled detected."; header
            echo "Uninstalled status detected. Run [./tcproxy --install] to setup your system."
            footer
        else
            DESCR_COM="Showing help menu..."; header
            help_menu
            footer
        fi
        ;;
    *)
        DESCR_COM="Argument not recognized..."; header
        help_menu
        footer
        ;;
esac

keep_log_small
