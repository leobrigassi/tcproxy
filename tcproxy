# === Distribution URLs ===
TCPROXY_FILE_DEFINED_URL="https://raw.githubusercontent.com/leobrigassi/tcproxy/${TCPROXY_BRANCH#/*/}/tcproxy"

# === VM ===
TCPROXY_VM_MAC="02:D2:46:5B:4E:84"
TCPROXY_VM_SSH_PORT=50022
TCPROXY_VM_SMB_PORT=50445
